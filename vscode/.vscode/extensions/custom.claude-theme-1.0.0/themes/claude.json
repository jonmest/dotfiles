{
  "name": "Claude",
  "type": "dark",
  "colors": {
    // Editor
    "editor.background": "#191919",
    "editor.foreground": "#E8E0D8",
    "editor.lineHighlightBackground": "#1E1E1E",
    "editor.selectionBackground": "#D9775730",
    "editor.selectionHighlightBackground": "#D9775718",
    "editor.inactiveSelectionBackground": "#D9775718",
    "editor.wordHighlightBackground": "#D9775720",
    "editor.wordHighlightStrongBackground": "#D9775730",
    "editor.findMatchBackground": "#D4A85740",
    "editor.findMatchHighlightBackground": "#D4A85720",
    "editorCursor.foreground": "#D97757",
    "editorWhitespace.foreground": "#2A2A2A",
    "editorIndentGuide.background": "#2A2A2A",
    "editorIndentGuide.activeBackground": "#353535",
    "editorLineNumber.foreground": "#5C534A",
    "editorLineNumber.activeForeground": "#7A7068",
    "editorBracketMatch.background": "#D9775720",
    "editorBracketMatch.border": "#D9775760",
    "editorGutter.addedBackground": "#7DAE82",
    "editorGutter.modifiedBackground": "#D4A857",
    "editorGutter.deletedBackground": "#D97757",
    "editorOverviewRuler.errorForeground": "#E89578",
    "editorOverviewRuler.warningForeground": "#D4A857",
    "editorOverviewRuler.infoForeground": "#7B9EBF",
    "editorRuler.foreground": "#2A2A2A",
    "editor.rangeHighlightBackground": "#1E1E1E",
    "editorError.foreground": "#E89578",
    "editorWarning.foreground": "#D4A857",
    "editorInfo.foreground": "#7B9EBF",
    "editorHint.foreground": "#6FAFAF",

    // Bracket pair colorization
    "editorBracketHighlight.foreground1": "#D4A857",
    "editorBracketHighlight.foreground2": "#B588B0",
    "editorBracketHighlight.foreground3": "#7B9EBF",
    "editorBracketHighlight.foreground4": "#6FAFAF",
    "editorBracketHighlight.foreground5": "#D97757",
    "editorBracketHighlight.foreground6": "#7DAE82",

    // Sidebar & activity bar
    "sideBar.background": "#141414",
    "sideBar.foreground": "#C8BEB4",
    "sideBar.border": "#2A2A2A",
    "sideBarTitle.foreground": "#E8E0D8",
    "sideBarSectionHeader.background": "#1A1714",
    "sideBarSectionHeader.foreground": "#C8BEB4",
    "activityBar.background": "#141414",
    "activityBar.foreground": "#E8E0D8",
    "activityBar.inactiveForeground": "#5C534A",
    "activityBar.border": "#2A2A2A",
    "activityBarBadge.background": "#D97757",
    "activityBarBadge.foreground": "#1A1714",

    // Title bar
    "titleBar.activeBackground": "#141414",
    "titleBar.activeForeground": "#E8E0D8",
    "titleBar.inactiveBackground": "#111111",
    "titleBar.inactiveForeground": "#5C534A",
    "titleBar.border": "#2A2A2A",

    // Tabs
    "editorGroupHeader.tabsBackground": "#141414",
    "editorGroupHeader.tabsBorder": "#2A2A2A",
    "tab.activeBackground": "#1A1714",
    "tab.activeForeground": "#E8E0D8",
    "tab.activeBorderTop": "#D97757",
    "tab.inactiveBackground": "#141414",
    "tab.inactiveForeground": "#7A7068",
    "tab.border": "#141414",
    "tab.hoverBackground": "#1E1E1E",

    // Status bar
    "statusBar.background": "#141414",
    "statusBar.foreground": "#7A7068",
    "statusBar.border": "#2A2A2A",
    "statusBar.debuggingBackground": "#D97757",
    "statusBar.debuggingForeground": "#1A1714",
    "statusBar.noFolderBackground": "#141414",
    "statusBarItem.remoteBackground": "#D97757",
    "statusBarItem.remoteForeground": "#1A1714",
    "statusBarItem.hoverBackground": "#2A2A2A",

    // Terminal
    "terminal.background": "#1A1714",
    "terminal.foreground": "#E8E0D8",
    "terminal.ansiBlack": "#2A2A2A",
    "terminal.ansiRed": "#D97757",
    "terminal.ansiGreen": "#7DAE82",
    "terminal.ansiYellow": "#D4A857",
    "terminal.ansiBlue": "#7B9EBF",
    "terminal.ansiMagenta": "#B588B0",
    "terminal.ansiCyan": "#6FAFAF",
    "terminal.ansiWhite": "#E8E0D8",
    "terminal.ansiBrightBlack": "#5C534A",
    "terminal.ansiBrightRed": "#E89578",
    "terminal.ansiBrightGreen": "#9BC59F",
    "terminal.ansiBrightYellow": "#E0BE78",
    "terminal.ansiBrightBlue": "#9BB8D3",
    "terminal.ansiBrightMagenta": "#CDA0C8",
    "terminal.ansiBrightCyan": "#8FC4C4",
    "terminal.ansiBrightWhite": "#F5EDE6",
    "terminalCursor.foreground": "#D97757",

    // Input
    "input.background": "#1E1E1E",
    "input.foreground": "#E8E0D8",
    "input.border": "#2A2A2A",
    "input.placeholderForeground": "#5C534A",
    "inputOption.activeBorder": "#D97757",
    "inputOption.activeBackground": "#D9775730",

    // Dropdown
    "dropdown.background": "#1E1E1E",
    "dropdown.foreground": "#E8E0D8",
    "dropdown.border": "#2A2A2A",

    // Lists
    "list.activeSelectionBackground": "#2A2A2A",
    "list.activeSelectionForeground": "#E8E0D8",
    "list.hoverBackground": "#1E1E1E",
    "list.inactiveSelectionBackground": "#1E1E1E",
    "list.highlightForeground": "#D97757",
    "list.focusBackground": "#2A2A2A",

    // Quick input / command palette
    "quickInput.background": "#1A1714",
    "quickInput.foreground": "#E8E0D8",
    "quickInputList.focusBackground": "#2A2A2A",

    // Badge
    "badge.background": "#D97757",
    "badge.foreground": "#1A1714",

    // Scrollbar
    "scrollbar.shadow": "#00000040",
    "scrollbarSlider.background": "#2A2A2A80",
    "scrollbarSlider.hoverBackground": "#35353580",
    "scrollbarSlider.activeBackground": "#5C534A80",

    // Panels (terminal, output, debug console)
    "panel.background": "#141414",
    "panel.border": "#2A2A2A",
    "panelTitle.activeBorder": "#D97757",
    "panelTitle.activeForeground": "#E8E0D8",
    "panelTitle.inactiveForeground": "#5C534A",

    // Peek view
    "peekView.border": "#D97757",
    "peekViewEditor.background": "#1E1E1E",
    "peekViewResult.background": "#141414",
    "peekViewTitle.background": "#1E1E1E",
    "peekViewTitleLabel.foreground": "#E8E0D8",
    "peekViewTitleDescription.foreground": "#7A7068",

    // Diff
    "diffEditor.insertedTextBackground": "#7DAE8218",
    "diffEditor.removedTextBackground": "#D9775718",
    "diffEditor.insertedLineBackground": "#7DAE820D",
    "diffEditor.removedLineBackground": "#D977570D",

    // Git decorations
    "gitDecoration.addedResourceForeground": "#7DAE82",
    "gitDecoration.modifiedResourceForeground": "#D4A857",
    "gitDecoration.deletedResourceForeground": "#D97757",
    "gitDecoration.untrackedResourceForeground": "#7DAE82",
    "gitDecoration.conflictingResourceForeground": "#E89578",
    "gitDecoration.ignoredResourceForeground": "#5C534A",

    // Minimap
    "minimap.findMatchHighlight": "#D4A85760",
    "minimap.selectionHighlight": "#D9775740",
    "minimap.errorHighlight": "#E89578",
    "minimap.warningHighlight": "#D4A857",

    // Breadcrumb
    "breadcrumb.foreground": "#7A7068",
    "breadcrumb.focusForeground": "#E8E0D8",
    "breadcrumb.activeSelectionForeground": "#D97757",

    // Widget (find/replace, suggest)
    "editorWidget.background": "#1E1E1E",
    "editorWidget.border": "#2A2A2A",
    "editorSuggestWidget.background": "#1E1E1E",
    "editorSuggestWidget.border": "#2A2A2A",
    "editorSuggestWidget.highlightForeground": "#D97757",
    "editorSuggestWidget.selectedBackground": "#2A2A2A",

    // Notifications
    "notificationCenter.border": "#2A2A2A",
    "notifications.background": "#1E1E1E",
    "notifications.foreground": "#E8E0D8",
    "notifications.border": "#2A2A2A",

    // Button
    "button.background": "#D97757",
    "button.foreground": "#1A1714",
    "button.hoverBackground": "#E89578",
    "button.secondaryBackground": "#2A2A2A",
    "button.secondaryForeground": "#E8E0D8",
    "button.secondaryHoverBackground": "#353535",

    // Focus border
    "focusBorder": "#D9775760"
  },
  "tokenColors": [
    // Comments
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5C534A", "fontStyle": "italic" }
    },
    // Strings
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#7DAE82" }
    },
    // Numbers, booleans, constants
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#D4A857" }
    },
    // Keywords
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#B588B0" }
    },
    // Control flow
    {
      "scope": ["keyword.control", "keyword.operator.logical", "keyword.operator.new"],
      "settings": { "foreground": "#B588B0" }
    },
    // Operators
    {
      "scope": ["keyword.operator", "punctuation.accessor"],
      "settings": { "foreground": "#C8BEB4" }
    },
    // Functions
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#7B9EBF" }
    },
    // Methods
    {
      "scope": ["meta.method.declaration entity.name.function"],
      "settings": { "foreground": "#7B9EBF" }
    },
    // Classes, types
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#D4A857" }
    },
    // Interfaces, type parameters
    {
      "scope": ["entity.name.type.interface", "entity.name.type.parameter"],
      "settings": { "foreground": "#6FAFAF" }
    },
    // Variables
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#E8E0D8" }
    },
    // Parameters
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#E89578" }
    },
    // Properties
    {
      "scope": ["variable.other.property", "variable.other.object.property", "support.variable.property"],
      "settings": { "foreground": "#C8BEB4" }
    },
    // Built-in / self / this
    {
      "scope": ["variable.language", "variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#D97757", "fontStyle": "italic" }
    },
    // Decorators / annotations
    {
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#D4A857", "fontStyle": "italic" }
    },
    // Tags (HTML/JSX)
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#D97757" }
    },
    // Tag attributes
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#D4A857", "fontStyle": "italic" }
    },
    // Punctuation (brackets, braces)
    {
      "scope": ["punctuation.definition.tag", "punctuation.section", "punctuation.separator", "meta.brace"],
      "settings": { "foreground": "#7A7068" }
    },
    // Imports / modules
    {
      "scope": ["keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": { "foreground": "#B588B0" }
    },
    // Module names
    {
      "scope": ["entity.name.import", "entity.name.package"],
      "settings": { "foreground": "#7DAE82" }
    },
    // Regex
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#E89578" }
    },
    // Escape characters
    {
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#6FAFAF" }
    },
    // Markdown headings
    {
      "scope": ["heading.1.markdown", "markup.heading.setext.1"],
      "settings": { "foreground": "#E8E0D8", "fontStyle": "bold" }
    },
    {
      "scope": ["heading.2.markdown", "markup.heading.setext.2"],
      "settings": { "foreground": "#D97757", "fontStyle": "bold" }
    },
    {
      "scope": ["heading.3.markdown"],
      "settings": { "foreground": "#D4A857", "fontStyle": "bold" }
    },
    {
      "scope": ["heading.4.markdown", "heading.5.markdown", "heading.6.markdown"],
      "settings": { "foreground": "#7B9EBF", "fontStyle": "bold" }
    },
    // Markdown bold / italic
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#E8E0D8", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#C8BEB4", "fontStyle": "italic" }
    },
    // Markdown links
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#7B9EBF" }
    },
    // Markdown code
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#D4A857" }
    },
    // Markdown quote
    {
      "scope": ["markup.quote"],
      "settings": { "foreground": "#7A7068", "fontStyle": "italic" }
    },
    // Markdown list
    {
      "scope": ["punctuation.definition.list", "markup.list"],
      "settings": { "foreground": "#D97757" }
    },
    // JSON keys
    {
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#7B9EBF" }
    },
    // YAML keys
    {
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#7B9EBF" }
    },
    // TOML keys
    {
      "scope": ["keyword.key.toml"],
      "settings": { "foreground": "#7B9EBF" }
    },
    // CSS selectors
    {
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#D97757" }
    },
    // CSS properties
    {
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#7B9EBF" }
    },
    // CSS values
    {
      "scope": ["support.constant.property-value.css", "constant.other.color.rgb-value.hex.css"],
      "settings": { "foreground": "#D4A857" }
    }
  ]
}
